# =========================
# ENV général (dev)
# =========================

# Backend
PORT=8001
NODE_ENV=development

# Base de données Supabase (Postgres)
# Exemple (Supabase) : postgres://postgres:<PASSWORD>@<HOST>:5432/postgres
#DATABASE_URL=

# JWT
JWT_SECRET=change-me

# CORS (URLs frontend)
FRONTEND_URL=http://localhost:3000
FRONTEND_URL_2=http://localhost:3001

# Email (SMTP) - utilisé pour confirmer l'email
EMAIL_FROM=no-reply@hopeveri.com
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Google OAuth (optionnel, /api/auth/google)
GOOGLE_CLIENT_ID=

# Seed admin (optionnel)
ADMIN_EMAIL=admin@hopeveri.com
ADMIN_PASSWORD=Admin123!

